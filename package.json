{
	"name": "ccsidekick-workspace",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"packages/core",
		"packages/packs/*"
	],
	"type": "module",
	"scripts": {
		"prepare": "[ -n \"$CI\" ] || git config core.hooksPath .githooks || true",
		"link:global": "bun run build && mkdir -p \"$HOME/.local/bin\" && ln -sf \"$PWD/packages/core/dist/ccsidekick-render.js\" \"$HOME/.local/bin/ccsidekick-render\" && ln -sf \"$PWD/packages/core/dist/ccsidekick.js\" \"$HOME/.local/bin/ccsidekick\"",
		"build": "bun run --cwd packages/core build",
		"test": "bun test && bun test ./.claude/skills/pack-author/scripts/",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.eslint.json --noEmit",
		"lint": "eslint .",
		"format": "prettier --write . --ignore-path .gitignore --ignore-path .prettierignore",
		"format:check": "prettier --check . --ignore-path .gitignore --ignore-path .prettierignore",
		"pack:lint": "bun packages/core/src/packs/lint.ts",
		"pack:readme": "scripts/assets/pack-readme.sh",
		"pack:shot": "scripts/assets/pack-shot.sh",
		"pricing:check": "bun packages/core/scripts/refresh-pricing.ts --check",
		"pricing:refresh": "bun packages/core/scripts/refresh-pricing.ts --write && prettier --write packages/core/src/data/pricing.json",
		"character:reel": "scripts/assets/character-reel.sh",
		"poster": "scripts/assets/poster.sh",
		"og": "scripts/assets/og.sh",
		"readme:drift": "bun packages/core/scripts/readme-drift.ts",
		"site:build": "bun run site:assets && bun run site:tokens && bun run site:data && bun run site:render-web",
		"site:assets": "bun run scripts/website/site-assets.ts",
		"site:tokens": "bun run scripts/website/site-tokens.ts",
		"site:data": "bun run scripts/website/site-data.ts",
		"site:render-web": "bun run scripts/website/build-render-web.ts",
		"site:drift": "bun run scripts/website/site-drift.ts",
		"site:serve": "bun run scripts/website/serve.ts",
		"changeset": "changeset",
		"ci:version": "changeset version && bun install",
		"ci:publish": "bash scripts/publish/ci-publish.sh && changeset tag"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@types/bun": "^1.3.0",
		"@types/node": "^20.19.0",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"eslint": "^9.39.0",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-import-x": "^4",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-regexp": "^3.1.1",
		"eslint-plugin-sonarjs": "^4.1.0",
		"eslint-plugin-unicorn": "^70.0.0",
		"prettier": "^3.9.0",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.62.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/krayong/ccsidekick.git"
	},
	"author": "Karan Gourisaria <ccsidekick@krayong.com>"
}
